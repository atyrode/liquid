#!/usr/bin/env bash
set -euo pipefail

repo_dir="${LIQUID_REPO_DIR:-$HOME/liquid}"
code_dir="$repo_dir/code"

if [ ! -d "$code_dir" ]; then
  echo "Liquid source checkout is missing: $code_dir" >&2
  exit 1
fi

cd "$code_dir"

args=(
  --auto-size
  --particles "${LIQUID_PARTICLES:-500}"
  --fps "${LIQUID_FPS:-20}"
  --color "${LIQUID_COLOR:-deep-blue}"
  --gravity-spin "${LIQUID_GRAVITY_SPIN:-1}"
)

if [ -x target/release/examples/terminal ]; then
  exec target/release/examples/terminal "${args[@]}" "$@"
fi

exec cargo run --release --no-default-features --example terminal -- "${args[@]}" "$@"
