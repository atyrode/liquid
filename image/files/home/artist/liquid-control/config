#!/usr/bin/env bash
set -euo pipefail

config_file="${LIQUID_CONFIG:-$HOME/liquid-control/settings.env}"
editor="${EDITOR:-nano}"

if ! command -v "$editor" >/dev/null 2>&1; then
  editor="vi"
fi

"$editor" "$config_file"

cat <<'EOF'

Renderer settings saved.
Apply them to the tmux renderer with:

  ~/liquid-control/restart
EOF
