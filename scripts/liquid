#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
default_repo_dir="$(cd -- "$script_dir/.." && pwd)"

repo_dir="${LIQUID_REPO_DIR:-$default_repo_dir}"
code_dir="$repo_dir/code"
config_dir="${LIQUID_CONFIG_DIR:-$repo_dir/.liquid}"
config_file="${LIQUID_CONFIG:-$config_dir/settings.env}"
session="${LIQUID_TMUX_SESSION:-liquid}"
terminal_bin="$code_dir/target/release/examples/terminal"
led_matrix_bin="$code_dir/target/release/examples/led_matrix"

usage() {
  cat <<'EOF'
Usage: liquid [COMMAND] [ARGS...]

One entrypoint for the Liquid Pi runtime.

Run without a command to open the terminal menu.

Commands:
  setup, settings      Open renderer setup/settings UI.
  run [ARGS...]        Run the renderer in the current terminal.
  run-led [ARGS...]    Run the renderer on a WS2812B LED matrix.
  led-test [ARGS...]   Run RGB/chase/row tests on a WS2812B LED matrix.
  led-orbit [ARGS...]  Run the green orbit LED matrix test.
  start [--attach]     Start the renderer in tmux.
  restart [--attach]   Restart the tmux renderer.
  attach               Attach to the tmux renderer.
  stop                 Stop the tmux renderer.
  update               Pull the current Git branch and rebuild the renderer.
  bluetooth            Pair/connect a Bluetooth keyboard or device.
  doctor               Run runtime diagnostics.
  install-system       Install/update this checkout as the Pi runtime.
  help                 Show this help.
EOF
}

need_repo() {
  if [ ! -d "$code_dir" ]; then
    echo "Liquid source checkout is missing: $code_dir" >&2
    exit 1
  fi
}

save_config_file() {
  mkdir -p "$(dirname -- "$config_file")"
  cat >"$config_file" <<'EOF'
# Local Liquid renderer settings.
# This file is written by `liquid setup` and ignored by git.

EOF
  cat >>"$config_file" <<EOF
LIQUID_PARTICLES=${LIQUID_PARTICLES:-500}
LIQUID_FPS=${LIQUID_FPS:-60}
LIQUID_COLOR=${LIQUID_COLOR:-deep-blue}
LIQUID_CHARSET=${LIQUID_CHARSET:-classic}
LIQUID_GRAVITY_SPIN=${LIQUID_GRAVITY_SPIN:-1}
LIQUID_STATUS=${LIQUID_STATUS:-0}
LIQUID_AUTO_SIZE=${LIQUID_AUTO_SIZE:-1}
LIQUID_COLS=${LIQUID_COLS:-100}
LIQUID_ROWS=${LIQUID_ROWS:-50}
LIQUID_LED_PANEL_WIDTH=${LIQUID_LED_PANEL_WIDTH:-8}
LIQUID_LED_PANEL_HEIGHT=${LIQUID_LED_PANEL_HEIGHT:-8}
LIQUID_LED_CHAIN_COLS=${LIQUID_LED_CHAIN_COLS:-1}
LIQUID_LED_CHAIN_ROWS=${LIQUID_LED_CHAIN_ROWS:-1}
LIQUID_LED_SERPENTINE=${LIQUID_LED_SERPENTINE:-1}
LIQUID_LED_ORIGIN=${LIQUID_LED_ORIGIN:-top-left}
LIQUID_LED_COLOR=${LIQUID_LED_COLOR:-${LIQUID_COLOR:-deep-blue}}
LIQUID_LED_BRIGHTNESS=${LIQUID_LED_BRIGHTNESS:-16}
LIQUID_LED_SPI_HZ=${LIQUID_LED_SPI_HZ:-3000000}
LIQUID_LED_FPS=${LIQUID_LED_FPS:-30}
LIQUID_LED_PARTICLES=${LIQUID_LED_PARTICLES:-500}
LIQUID_LED_GRAVITY_SPIN=${LIQUID_LED_GRAVITY_SPIN:-${LIQUID_GRAVITY_SPIN:-1}}
EOF
}

write_default_config() {
  LIQUID_PARTICLES=500
  LIQUID_FPS=60
  LIQUID_COLOR=deep-blue
  LIQUID_CHARSET=classic
  LIQUID_GRAVITY_SPIN=1
  LIQUID_STATUS=0
  LIQUID_AUTO_SIZE=1
  LIQUID_COLS=100
  LIQUID_ROWS=50
  LIQUID_LED_PANEL_WIDTH=8
  LIQUID_LED_PANEL_HEIGHT=8
  LIQUID_LED_CHAIN_COLS=1
  LIQUID_LED_CHAIN_ROWS=1
  LIQUID_LED_SERPENTINE=1
  LIQUID_LED_ORIGIN=top-left
  LIQUID_LED_COLOR=deep-blue
  LIQUID_LED_BRIGHTNESS=16
  LIQUID_LED_SPI_HZ=3000000
  LIQUID_LED_FPS=30
  LIQUID_LED_PARTICLES=500
  LIQUID_LED_GRAVITY_SPIN=1
  save_config_file
}

ensure_config_file() {
  if [ ! -f "$config_file" ]; then
    write_default_config
  fi
}

load_config() {
  ensure_config_file
  set -a
  # shellcheck source=/dev/null
  . "$config_file"
  set +a
}

build_renderer_args() {
  renderer_args=()

  case "${LIQUID_AUTO_SIZE:-1}" in
    1|true|yes|on)
      renderer_args+=(--auto-size)
      ;;
    0|false|no|off)
      renderer_args+=(--fixed-size --cols "${LIQUID_COLS:-100}" --rows "${LIQUID_ROWS:-50}")
      ;;
    *)
      echo "Invalid LIQUID_AUTO_SIZE value: ${LIQUID_AUTO_SIZE}" >&2
      exit 2
      ;;
  esac

  renderer_args+=(
    --particles "${LIQUID_PARTICLES:-500}"
    --fps "${LIQUID_FPS:-60}"
    --color "${LIQUID_COLOR:-deep-blue}"
    --charset "${LIQUID_CHARSET:-classic}"
    --gravity-spin "${LIQUID_GRAVITY_SPIN:-1}"
  )

  case "${LIQUID_STATUS:-0}" in
    1|true|yes|on)
      renderer_args+=(--status)
      ;;
    0|false|no|off|"")
      renderer_args+=(--no-status)
      ;;
    *)
      echo "Invalid LIQUID_STATUS value: ${LIQUID_STATUS}" >&2
      exit 2
      ;;
  esac
}

build_led_renderer_args() {
  led_args=(
    --panel-width "${LIQUID_LED_PANEL_WIDTH:-8}"
    --panel-height "${LIQUID_LED_PANEL_HEIGHT:-8}"
    --chain-cols "${LIQUID_LED_CHAIN_COLS:-1}"
    --chain-rows "${LIQUID_LED_CHAIN_ROWS:-1}"
    --origin "${LIQUID_LED_ORIGIN:-top-left}"
    --brightness "${LIQUID_LED_BRIGHTNESS:-16}"
    --spi-hz "${LIQUID_LED_SPI_HZ:-3000000}"
    --fps "${LIQUID_LED_FPS:-30}"
    --particles "${LIQUID_LED_PARTICLES:-500}"
    --color "${LIQUID_LED_COLOR:-${LIQUID_COLOR:-deep-blue}}"
    --gravity-spin "${LIQUID_LED_GRAVITY_SPIN:-${LIQUID_GRAVITY_SPIN:-1}}"
  )

  case "${LIQUID_LED_SERPENTINE:-1}" in
    1|true|yes|on)
      led_args+=(--serpentine)
      ;;
    0|false|no|off)
      led_args+=(--linear)
      ;;
    *)
      echo "Invalid LIQUID_LED_SERPENTINE value: ${LIQUID_LED_SERPENTINE}" >&2
      exit 2
      ;;
  esac
}

ensure_terminal_binary() {
  need_repo

  local needs_build=0
  if [ ! -x "$terminal_bin" ]; then
    needs_build=1
  elif find "$code_dir/Cargo.toml" "$code_dir/Cargo.lock" "$code_dir/src" "$code_dir/examples" \
    -type f -newer "$terminal_bin" -print -quit | grep -q .; then
    needs_build=1
  fi

  if [ "$needs_build" -eq 1 ]; then
    printf '+ (cd %q && cargo build --release --no-default-features --example terminal)\n' "$code_dir"
    (cd "$code_dir" && cargo build --release --no-default-features --example terminal)
  fi
}

ensure_led_matrix_binary() {
  need_repo

  local needs_build=0
  if [ ! -x "$led_matrix_bin" ]; then
    needs_build=1
  elif find "$code_dir/Cargo.toml" "$code_dir/Cargo.lock" "$code_dir/src" "$code_dir/examples" \
    -type f -newer "$led_matrix_bin" -print -quit | grep -q .; then
    needs_build=1
  fi

  if [ "$needs_build" -eq 1 ]; then
    printf '+ (cd %q && cargo build --release --no-default-features --features led-matrix --example led_matrix)\n' "$code_dir"
    (cd "$code_dir" && cargo build --release --no-default-features --features led-matrix --example led_matrix)
  fi
}

run_renderer() {
  export LIQUID_CONFIG="$config_file"
  load_config
  ensure_terminal_binary
  build_renderer_args
  exec "$terminal_bin" "${renderer_args[@]}" "$@"
}

run_led_renderer() {
  export LIQUID_CONFIG="$config_file"
  load_config
  ensure_led_matrix_binary
  build_led_renderer_args
  exec "$led_matrix_bin" "${led_args[@]}" "$@"
}

run_led_test() {
  run_led_renderer --test "$@"
}

run_led_orbit() {
  run_led_renderer --orbit-test "$@"
}

dialog_available() {
  command -v dialog >/dev/null 2>&1 && [ -t 0 ] && [ -t 1 ]
}

bool_label() {
  case "${1:-0}" in
    1|true|yes|on)
      printf 'on'
      ;;
    *)
      printf 'off'
      ;;
  esac
}

toggle_bool_var() {
  local var="$1"

  case "${!var:-0}" in
    1|true|yes|on)
      printf -v "$var" '0'
      ;;
    *)
      printf -v "$var" '1'
      ;;
  esac
}

show_setup_error() {
  local message="$1"

  if dialog_available; then
    dialog --title "Liquid settings" --msgbox "$message" 8 72
  else
    echo "$message" >&2
  fi
}

set_number_var() {
  local var="$1"
  local label="$2"
  local value="$3"
  local min="$4"
  local max="$5"
  local kind="$6"
  local normalized

  if [ "$kind" = "int" ]; then
    if ! [[ "$value" =~ ^[0-9]+$ ]]; then
      show_setup_error "$label must be an integer."
      return 1
    fi

    normalized=$((10#$value))
    if (( normalized < min || normalized > max )); then
      show_setup_error "$label must be between $min and $max."
      return 1
    fi
  else
    if ! [[ "$value" =~ ^-?[0-9]+([.][0-9]+)?$ ]]; then
      show_setup_error "$label must be a number."
      return 1
    fi

    if ! awk -v value="$value" -v min="$min" -v max="$max" 'BEGIN { exit !(value >= min && value <= max) }'; then
      show_setup_error "$label must be between $min and $max."
      return 1
    fi
    normalized="$(awk -v value="$value" 'BEGIN { printf "%g", value }')"
  fi

  printf -v "$var" '%s' "$normalized"
}

adjust_number_var() {
  local var="$1"
  local delta="$2"
  local min="$3"
  local max="$4"
  local kind="$5"
  local current="${!var:-$min}"
  local next

  if [ "$kind" = "int" ]; then
    if ! [[ "$current" =~ ^[0-9]+$ ]]; then
      current="$min"
    fi

    next=$((10#$current + delta))
    if (( next < min )); then
      next="$min"
    elif (( next > max )); then
      next="$max"
    fi
  else
    if ! [[ "$current" =~ ^-?[0-9]+([.][0-9]+)?$ ]]; then
      current="$min"
    fi

    next="$(
      awk -v current="$current" -v delta="$delta" -v min="$min" -v max="$max" \
        'BEGIN { result = current + delta; if (result < min) result = min; if (result > max) result = max; printf "%g", result }'
    )"
  fi

  printf -v "$var" '%s' "$next"
}

dialog_edit_number() {
  local var="$1"
  local label="$2"
  local min="$3"
  local max="$4"
  local fine_step="$5"
  local rough_step="$6"
  local kind="$7"
  local choice value

  while true; do
    choice="$(
      dialog --stdout --clear \
        --title "$label" \
        --menu "Current: ${!var:-}. Enter an exact value, or apply a fine/rough step." 18 78 8 \
        exact "Enter exact value" \
        inc-fine "+$fine_step fine step" \
        dec-fine "-$fine_step fine step" \
        inc-rough "+$rough_step rough step" \
        dec-rough "-$rough_step rough step" \
        back "Back"
    )" || return 0

    case "$choice" in
      exact)
        value="$(
          dialog --stdout --clear \
            --title "$label" \
            --inputbox "Enter $label ($min to $max)." 8 72 "${!var:-}"
        )" || continue
        set_number_var "$var" "$label" "$value" "$min" "$max" "$kind" && return 0
        ;;
      inc-fine)
        adjust_number_var "$var" "$fine_step" "$min" "$max" "$kind"
        ;;
      dec-fine)
        adjust_number_var "$var" "-$fine_step" "$min" "$max" "$kind"
        ;;
      inc-rough)
        adjust_number_var "$var" "$rough_step" "$min" "$max" "$kind"
        ;;
      dec-rough)
        adjust_number_var "$var" "-$rough_step" "$min" "$max" "$kind"
        ;;
      back)
        return 0
        ;;
    esac
  done
}

dialog_select_value() {
  local var="$1"
  local label="$2"
  shift 2
  local choice

  choice="$(
    dialog --stdout --clear \
      --title "$label" \
      --menu "Current: ${!var:-}" 16 72 8 \
      "$@"
  )" || return 0

  printf -v "$var" '%s' "$choice"
}

start_terminal_from_setup() {
  ensure_terminal_binary
  build_renderer_args
  exec "$terminal_bin" "${renderer_args[@]}" "$@"
}

start_led_from_setup() {
  ensure_led_matrix_binary
  build_led_renderer_args
  exec "$led_matrix_bin" "${led_args[@]}" "$@"
}

run_dialog_setup() {
  local choice

  while true; do
    choice="$(
      dialog --stdout --clear \
        --title "Liquid settings" \
        --menu "Edit runtime settings. Numeric values support exact entry plus fine and rough steps." 22 78 14 \
        start-terminal "Start terminal renderer with current values" \
        save-start-terminal "Save settings, then start terminal renderer" \
        start-led "Start LED matrix renderer with current values" \
        save "Save settings to $config_file" \
        terminal-particles "Terminal particles: ${LIQUID_PARTICLES:-500}" \
        terminal-fps "Terminal FPS: ${LIQUID_FPS:-60}" \
        terminal-color "Terminal color: ${LIQUID_COLOR:-deep-blue}" \
        terminal-charset "Terminal charset: ${LIQUID_CHARSET:-classic}" \
        terminal-gravity "Terminal gravity spin: ${LIQUID_GRAVITY_SPIN:-1}" \
        terminal-status "Terminal status line: $(bool_label "${LIQUID_STATUS:-0}")" \
        terminal-auto-size "Terminal auto-size: $(bool_label "${LIQUID_AUTO_SIZE:-1}")" \
        terminal-cols "Terminal fixed columns: ${LIQUID_COLS:-100}" \
        terminal-rows "Terminal fixed rows: ${LIQUID_ROWS:-50}" \
        led-particles "LED particles: ${LIQUID_LED_PARTICLES:-500}" \
        led-fps "LED FPS: ${LIQUID_LED_FPS:-30}" \
        led-color "LED color: ${LIQUID_LED_COLOR:-${LIQUID_COLOR:-deep-blue}}" \
        led-brightness "LED brightness: ${LIQUID_LED_BRIGHTNESS:-16}" \
        led-panel-width "LED panel width: ${LIQUID_LED_PANEL_WIDTH:-8}" \
        led-panel-height "LED panel height: ${LIQUID_LED_PANEL_HEIGHT:-8}" \
        led-chain-cols "LED chain columns: ${LIQUID_LED_CHAIN_COLS:-1}" \
        led-chain-rows "LED chain rows: ${LIQUID_LED_CHAIN_ROWS:-1}" \
        led-serpentine "LED serpentine wiring: $(bool_label "${LIQUID_LED_SERPENTINE:-1}")" \
        led-origin "LED first-pixel origin: ${LIQUID_LED_ORIGIN:-top-left}" \
        led-spi-hz "LED SPI Hz: ${LIQUID_LED_SPI_HZ:-3000000}" \
        led-gravity "LED gravity spin: ${LIQUID_LED_GRAVITY_SPIN:-${LIQUID_GRAVITY_SPIN:-1}}" \
        quit "Back to shell"
    )" || return 0

    case "$choice" in
      start-terminal)
        start_terminal_from_setup "$@"
        ;;
      save-start-terminal)
        save_config_file
        start_terminal_from_setup "$@"
        ;;
      start-led)
        start_led_from_setup "$@"
        ;;
      save)
        save_config_file
        dialog --title "Liquid settings" --msgbox "Saved settings to $config_file." 7 72
        ;;
      terminal-particles)
        dialog_edit_number LIQUID_PARTICLES "Terminal particles" 100 20000 100 1000 int
        ;;
      terminal-fps)
        dialog_edit_number LIQUID_FPS "Terminal FPS" 1 120 1 10 int
        ;;
      terminal-color)
        dialog_select_value LIQUID_COLOR "Terminal color" \
          deep-blue "Deep blue" \
          blue "Blue" \
          cyan "Cyan" \
          mono "Mono"
        ;;
      terminal-charset)
        dialog_select_value LIQUID_CHARSET "Terminal charset" \
          classic "Classic ASCII ramp" \
          dots "Dotted density marks" \
          blocks "Shaded block cells" \
          solid "Full block cells"
        ;;
      terminal-gravity)
        dialog_edit_number LIQUID_GRAVITY_SPIN "Terminal gravity spin" -10 10 0.1 1 float
        ;;
      terminal-status)
        toggle_bool_var LIQUID_STATUS
        ;;
      terminal-auto-size)
        toggle_bool_var LIQUID_AUTO_SIZE
        ;;
      terminal-cols)
        dialog_edit_number LIQUID_COLS "Terminal fixed columns" 1 300 1 10 int
        ;;
      terminal-rows)
        dialog_edit_number LIQUID_ROWS "Terminal fixed rows" 1 200 1 10 int
        ;;
      led-particles)
        dialog_edit_number LIQUID_LED_PARTICLES "LED particles" 1 10000 50 500 int
        ;;
      led-fps)
        dialog_edit_number LIQUID_LED_FPS "LED FPS" 1 120 1 10 int
        ;;
      led-color)
        dialog_select_value LIQUID_LED_COLOR "LED color" \
          deep-blue "Deep blue" \
          blue "Blue" \
          cyan "Cyan" \
          white "White"
        ;;
      led-brightness)
        dialog_edit_number LIQUID_LED_BRIGHTNESS "LED brightness" 0 255 1 16 int
        ;;
      led-panel-width)
        dialog_edit_number LIQUID_LED_PANEL_WIDTH "LED panel width" 1 128 1 8 int
        ;;
      led-panel-height)
        dialog_edit_number LIQUID_LED_PANEL_HEIGHT "LED panel height" 1 128 1 8 int
        ;;
      led-chain-cols)
        dialog_edit_number LIQUID_LED_CHAIN_COLS "LED chain columns" 1 16 1 3 int
        ;;
      led-chain-rows)
        dialog_edit_number LIQUID_LED_CHAIN_ROWS "LED chain rows" 1 16 1 2 int
        ;;
      led-serpentine)
        toggle_bool_var LIQUID_LED_SERPENTINE
        ;;
      led-origin)
        dialog_select_value LIQUID_LED_ORIGIN "LED first-pixel origin" \
          top-left "Top left" \
          top-right "Top right" \
          bottom-left "Bottom left" \
          bottom-right "Bottom right"
        ;;
      led-spi-hz)
        dialog_edit_number LIQUID_LED_SPI_HZ "LED SPI Hz" 2000000 3800000 100000 500000 int
        ;;
      led-gravity)
        dialog_edit_number LIQUID_LED_GRAVITY_SPIN "LED gravity spin" -10 10 0.1 1 float
        ;;
      quit)
        return 0
        ;;
    esac
  done
}

text_edit_number() {
  local var="$1"
  local label="$2"
  local min="$3"
  local max="$4"
  local fine_step="$5"
  local rough_step="$6"
  local kind="$7"
  local answer

  while true; do
    printf '%s is %s. Enter exact value, +/- for fine, ++/-- for rough, or blank to go back: ' "$label" "${!var:-}"
    read -r answer
    case "$answer" in
      "")
        return 0
        ;;
      +)
        adjust_number_var "$var" "$fine_step" "$min" "$max" "$kind"
        return 0
        ;;
      -)
        adjust_number_var "$var" "-$fine_step" "$min" "$max" "$kind"
        return 0
        ;;
      ++)
        adjust_number_var "$var" "$rough_step" "$min" "$max" "$kind"
        return 0
        ;;
      --)
        adjust_number_var "$var" "-$rough_step" "$min" "$max" "$kind"
        return 0
        ;;
      *)
        set_number_var "$var" "$label" "$answer" "$min" "$max" "$kind" && return 0
        ;;
    esac
  done
}

text_select_value() {
  local var="$1"
  local label="$2"
  shift 2
  local options=("$@")
  local answer index value

  echo
  echo "$label is ${!var:-}."
  for ((index = 0; index < ${#options[@]}; index += 2)); do
    printf '%d. %s\n' "$((index / 2 + 1))" "${options[index + 1]}"
  done
  printf 'Choose a value, or blank to go back: '
  read -r answer
  if [ -z "$answer" ]; then
    return 0
  fi
  if ! [[ "$answer" =~ ^[0-9]+$ ]]; then
    show_setup_error "Choose a number from the list."
    return 1
  fi

  index=$(((10#$answer - 1) * 2))
  if (( index < 0 || index >= ${#options[@]} )); then
    show_setup_error "Choose a number from the list."
    return 1
  fi

  value="${options[index]}"
  printf -v "$var" '%s' "$value"
}

run_text_setup() {
  local choice

  while true; do
    cat <<EOF
Liquid settings

1. Start terminal renderer with current values
2. Save settings, then start terminal renderer
3. Start LED matrix renderer with current values
4. Save settings
5. Terminal particles: ${LIQUID_PARTICLES:-500}
6. Terminal FPS: ${LIQUID_FPS:-60}
7. Terminal color: ${LIQUID_COLOR:-deep-blue}
8. Terminal charset: ${LIQUID_CHARSET:-classic}
9. Terminal gravity spin: ${LIQUID_GRAVITY_SPIN:-1}
10. Terminal status line: $(bool_label "${LIQUID_STATUS:-0}")
11. Terminal auto-size: $(bool_label "${LIQUID_AUTO_SIZE:-1}")
12. Terminal fixed columns: ${LIQUID_COLS:-100}
13. Terminal fixed rows: ${LIQUID_ROWS:-50}
14. LED particles: ${LIQUID_LED_PARTICLES:-500}
15. LED FPS: ${LIQUID_LED_FPS:-30}
16. LED color: ${LIQUID_LED_COLOR:-${LIQUID_COLOR:-deep-blue}}
17. LED brightness: ${LIQUID_LED_BRIGHTNESS:-16}
18. LED panel width: ${LIQUID_LED_PANEL_WIDTH:-8}
19. LED panel height: ${LIQUID_LED_PANEL_HEIGHT:-8}
20. LED chain columns: ${LIQUID_LED_CHAIN_COLS:-1}
21. LED chain rows: ${LIQUID_LED_CHAIN_ROWS:-1}
22. LED serpentine wiring: $(bool_label "${LIQUID_LED_SERPENTINE:-1}")
23. LED first-pixel origin: ${LIQUID_LED_ORIGIN:-top-left}
24. LED SPI Hz: ${LIQUID_LED_SPI_HZ:-3000000}
25. LED gravity spin: ${LIQUID_LED_GRAVITY_SPIN:-${LIQUID_GRAVITY_SPIN:-1}}
0. Quit

Numeric settings accept exact values, +/- fine steps, and ++/-- rough steps.
EOF
    printf 'Choose: '
    read -r choice

    case "$choice" in
      1)
        start_terminal_from_setup "$@"
        ;;
      2)
        save_config_file
        start_terminal_from_setup "$@"
        ;;
      3)
        start_led_from_setup "$@"
        ;;
      4)
        save_config_file
        echo "Saved settings to $config_file."
        ;;
      5)
        text_edit_number LIQUID_PARTICLES "Terminal particles" 100 20000 100 1000 int
        ;;
      6)
        text_edit_number LIQUID_FPS "Terminal FPS" 1 120 1 10 int
        ;;
      7)
        text_select_value LIQUID_COLOR "Terminal color" \
          deep-blue "Deep blue" \
          blue "Blue" \
          cyan "Cyan" \
          mono "Mono"
        ;;
      8)
        text_select_value LIQUID_CHARSET "Terminal charset" \
          classic "Classic ASCII ramp" \
          dots "Dotted density marks" \
          blocks "Shaded block cells" \
          solid "Full block cells"
        ;;
      9)
        text_edit_number LIQUID_GRAVITY_SPIN "Terminal gravity spin" -10 10 0.1 1 float
        ;;
      10)
        toggle_bool_var LIQUID_STATUS
        ;;
      11)
        toggle_bool_var LIQUID_AUTO_SIZE
        ;;
      12)
        text_edit_number LIQUID_COLS "Terminal fixed columns" 1 300 1 10 int
        ;;
      13)
        text_edit_number LIQUID_ROWS "Terminal fixed rows" 1 200 1 10 int
        ;;
      14)
        text_edit_number LIQUID_LED_PARTICLES "LED particles" 1 10000 50 500 int
        ;;
      15)
        text_edit_number LIQUID_LED_FPS "LED FPS" 1 120 1 10 int
        ;;
      16)
        text_select_value LIQUID_LED_COLOR "LED color" \
          deep-blue "Deep blue" \
          blue "Blue" \
          cyan "Cyan" \
          white "White"
        ;;
      17)
        text_edit_number LIQUID_LED_BRIGHTNESS "LED brightness" 0 255 1 16 int
        ;;
      18)
        text_edit_number LIQUID_LED_PANEL_WIDTH "LED panel width" 1 128 1 8 int
        ;;
      19)
        text_edit_number LIQUID_LED_PANEL_HEIGHT "LED panel height" 1 128 1 8 int
        ;;
      20)
        text_edit_number LIQUID_LED_CHAIN_COLS "LED chain columns" 1 16 1 3 int
        ;;
      21)
        text_edit_number LIQUID_LED_CHAIN_ROWS "LED chain rows" 1 16 1 2 int
        ;;
      22)
        toggle_bool_var LIQUID_LED_SERPENTINE
        ;;
      23)
        text_select_value LIQUID_LED_ORIGIN "LED first-pixel origin" \
          top-left "Top left" \
          top-right "Top right" \
          bottom-left "Bottom left" \
          bottom-right "Bottom right"
        ;;
      24)
        text_edit_number LIQUID_LED_SPI_HZ "LED SPI Hz" 2000000 3800000 100000 500000 int
        ;;
      25)
        text_edit_number LIQUID_LED_GRAVITY_SPIN "LED gravity spin" -10 10 0.1 1 float
        ;;
      0|q|quit)
        return 0
        ;;
    esac
  done
}

open_setup() {
  export LIQUID_CONFIG="$config_file"
  load_config

  if dialog_available; then
    run_dialog_setup "$@"
  else
    run_text_setup "$@"
  fi
}

start_renderer() {
  local attach=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --attach)
        attach=1
        shift
        ;;
      -h|--help)
        echo "Usage: liquid start [--attach]"
        exit 0
        ;;
      *)
        echo "Unknown option for start: $1" >&2
        exit 2
        ;;
    esac
  done

  if ! command -v tmux >/dev/null 2>&1; then
    run_renderer
  fi

  if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$repo_dir" "$repo_dir/scripts/liquid run"
  fi

  if [ "$attach" -eq 1 ]; then
    exec tmux attach-session -t "$session"
  fi

  echo "Liquid renderer is running in tmux session: $session"
  echo "Attach with: liquid attach"
}

restart_renderer() {
  local attach=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --attach)
        attach=1
        shift
        ;;
      -h|--help)
        echo "Usage: liquid restart [--attach]"
        exit 0
        ;;
      *)
        echo "Unknown option for restart: $1" >&2
        exit 2
        ;;
    esac
  done

  if ! command -v tmux >/dev/null 2>&1; then
    run_renderer
  fi

  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session"
  fi

  tmux new-session -d -s "$session" -c "$repo_dir" "$repo_dir/scripts/liquid run"

  if [ "$attach" -eq 1 ]; then
    exec tmux attach-session -t "$session"
  fi

  echo "Liquid renderer restarted in tmux session: $session"
  echo "Attach with: liquid attach"
}

attach_renderer() {
  if ! command -v tmux >/dev/null 2>&1; then
    echo "tmux is not installed; run in the current terminal with: liquid run" >&2
    exit 1
  fi

  if ! tmux has-session -t "$session" 2>/dev/null; then
    echo "No tmux session named $session is running. Start it with: liquid start" >&2
    exit 1
  fi

  exec tmux attach-session -t "$session"
}

stop_renderer() {
  if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$session" 2>/dev/null; then
    exec tmux kill-session -t "$session"
  fi

  echo "No tmux session named $session is running."
}

update_checkout() {
  if [ ! -d "$repo_dir/.git" ]; then
    echo "Liquid repo checkout is missing: $repo_dir" >&2
    exit 1
  fi

  cd "$repo_dir"

  local branch
  branch="$(git symbolic-ref --quiet --short HEAD || true)"
  if [ -z "$branch" ]; then
    echo "Liquid repo is detached; checkout the branch you want before updating." >&2
    exit 1
  fi

  git fetch --prune origin
  git pull --ff-only origin "$branch"
  ensure_terminal_binary

  echo "Updated $repo_dir on branch $branch."
}

run() {
  printf '+'
  printf ' %q' "$@"
  printf '\n'
  "$@"
}

run_optional() {
  printf '+'
  printf ' %q' "$@"
  printf '\n'
  if ! "$@"; then
    echo "Command failed; continuing because this cleanup step is optional." >&2
  fi
}

install_home_file() {
  local source="$1"
  local target="$2"

  if [ -e "$target" ] && ! cmp -s "$source" "$target"; then
    local backup="$target.local-before-liquid-install"
    local index=1
    while [ -e "$backup" ]; do
      backup="$target.local-before-liquid-install.$index"
      index=$((index + 1))
    done
    run mv "$target" "$backup"
  fi

  run install -m 0644 "$source" "$target"
}

install_system() {
  local assume_yes=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -y|--yes)
        assume_yes=1
        shift
        ;;
      -h|--help)
        cat <<'EOF'
Usage: liquid install-system [--yes]

Install this repo checkout as the Pi runtime:
- install /usr/local/bin/liquid as a thin shim into this checkout
- install/update the liquid-renderer systemd unit
- install the Liquid zsh loader files
- remove old split helper commands and ~/liquid-control
EOF
        exit 0
        ;;
      *)
        echo "Unknown option for install-system: $1" >&2
        exit 2
        ;;
    esac
  done

  need_repo

  if [ "$(id -u)" -eq 0 ]; then
    echo "Run this as the normal Pi user, not with sudo. The command uses sudo only where needed." >&2
    exit 1
  fi

  if ! command -v sudo >/dev/null 2>&1; then
    echo "sudo is required for installing /usr/local/bin/liquid and the systemd unit." >&2
    exit 1
  fi

  if ! command -v systemctl >/dev/null 2>&1; then
    echo "systemctl is required; this installer is for the Raspberry Pi OS image runtime." >&2
    exit 1
  fi

  if [ ! -f "$repo_dir/image/files/usr/local/bin/liquid" ]; then
    echo "Missing baked liquid shim source in the repo checkout." >&2
    exit 1
  fi

  if [ ! -f "$repo_dir/image/files/home/artist/.zshrc" ] ||
    [ ! -f "$repo_dir/image/files/home/artist/.liquid-shell.zsh" ]; then
    echo "Missing baked zsh loader sources in the repo checkout." >&2
    exit 1
  fi

  if [ "$assume_yes" -eq 0 ]; then
    cat <<EOF
This will install/update the Liquid Pi runtime from:
  $repo_dir

It will:
- install /usr/local/bin/liquid as the only user-facing runtime command
- install/update /etc/systemd/system/liquid-renderer.service
- install ~/.zshrc and ~/.liquid-shell.zsh so shell aliases load from this repo
- build the terminal renderer if needed
- stop/re-enable the liquid-renderer service
- remove old helper commands and ~/liquid-control

It will keep:
- this Git checkout
- Wi-Fi, Bluetooth, SSH, and system settings
- local renderer settings in $config_file
EOF

    if [ ! -t 0 ]; then
      echo "Re-run with --yes to approve non-interactively." >&2
      exit 1
    fi

    printf 'Continue? [y/N] '
    local answer
    read -r answer
    case "${answer,,}" in
      y|yes) ;;
      *)
        echo "No changes made."
        exit 0
        ;;
    esac
  fi

  if [ ! -f "$config_file" ] && [ -f "$HOME/liquid-control/settings.env" ]; then
    run mkdir -p "$config_dir"
    run cp "$HOME/liquid-control/settings.env" "$config_file"
  else
    ensure_config_file
  fi

  ensure_terminal_binary

  local user group service_file
  user="$(id -un)"
  group="$(id -gn)"
  service_file="$(mktemp)"

  cat >"$service_file" <<EOF
[Unit]
Description=Start Liquid terminal renderer in tmux
After=local-fs.target liquid-grow-rootfs.service
ConditionPathExists=$terminal_bin

[Service]
Type=oneshot
User=$user
Group=$group
WorkingDirectory=$HOME
Environment=LIQUID_NO_FASTFETCH=1
ExecStart=/usr/local/bin/liquid start
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

  run sudo install -m 0755 "$repo_dir/image/files/usr/local/bin/liquid" /usr/local/bin/liquid
  run sudo install -m 0644 "$service_file" /etc/systemd/system/liquid-renderer.service
  run rm -f "$service_file"
  install_home_file "$repo_dir/image/files/home/artist/.zshrc" "$HOME/.zshrc"
  install_home_file "$repo_dir/image/files/home/artist/.liquid-shell.zsh" "$HOME/.liquid-shell.zsh"
  run_optional tmux kill-session -t "$session"
  run_optional sudo systemctl stop liquid-renderer.service
  run sudo rm -f \
    /usr/local/bin/liquid-run-terminal \
    /usr/local/bin/liquid-start \
    /usr/local/bin/liquid-restart \
    /usr/local/bin/liquid-update \
    /usr/local/bin/liquid-bluetooth-keyboard \
    /usr/local/sbin/liquid-bootstrap \
    /usr/local/sbin/liquid-doctor
  run rm -rf "$HOME/liquid-control"
  run sudo systemctl daemon-reload
  run sudo systemctl enable liquid-renderer.service

  cat <<'EOF'

Liquid system runtime is installed.

Next:
  zconf
  liquid
EOF
}

run_bluetooth() {
  exec "$repo_dir/scripts/bluetooth-keyboard.sh" "$@"
}

run_doctor() {
  exec "$repo_dir/scripts/pi-doctor.sh" "$@"
}

show_menu() {
  local choice

  if command -v dialog >/dev/null 2>&1 && [ -t 0 ] && [ -t 1 ]; then
    choice="$(
      dialog --stdout --clear \
        --title "Liquid" \
        --menu "Choose an action" 22 74 13 \
        setup "Renderer setup/settings" \
        start "Start renderer in tmux" \
        attach "Attach to renderer tmux" \
        restart "Restart renderer tmux" \
        stop "Stop renderer tmux" \
        led-test "Test WS2812B LED matrix wiring" \
        led-orbit "Run green LED orbit test" \
        run-led "Run renderer on WS2812B LED matrix" \
        update "Pull repo and rebuild renderer" \
        bluetooth "Pair/connect Bluetooth keyboard" \
        doctor "Run diagnostics" \
        install-system "Install/update Pi system runtime" \
        quit "Quit"
    )" || exit 0
    clear || true
  else
    cat <<'EOF'
Liquid

1. Renderer setup/settings
2. Start renderer in tmux
3. Attach to renderer tmux
4. Restart renderer tmux
5. Stop renderer tmux
6. Test WS2812B LED matrix wiring
7. Run green LED orbit test
8. Run renderer on WS2812B LED matrix
9. Pull repo and rebuild renderer
10. Pair/connect Bluetooth keyboard
11. Run diagnostics
12. Install/update Pi system runtime
0. Quit

EOF
    printf 'Choose: '
    read -r choice
    case "$choice" in
      1) choice="setup" ;;
      2) choice="start" ;;
      3) choice="attach" ;;
      4) choice="restart" ;;
      5) choice="stop" ;;
      6) choice="led-test" ;;
      7) choice="led-orbit" ;;
      8) choice="run-led" ;;
      9) choice="update" ;;
      10) choice="bluetooth" ;;
      11) choice="doctor" ;;
      12) choice="install-system" ;;
      0) choice="quit" ;;
    esac
  fi

  dispatch "$choice"
}

dispatch() {
  local command="${1:-menu}"
  if [ "$#" -gt 0 ]; then
    shift
  fi

  case "$command" in
    ""|menu)
      show_menu
      ;;
    setup|settings)
      open_setup "$@"
      ;;
    run)
      run_renderer "$@"
      ;;
    run-led|led-run)
      run_led_renderer "$@"
      ;;
    led-test|test-led)
      run_led_test "$@"
      ;;
    led-orbit|orbit-led)
      run_led_orbit "$@"
      ;;
    start)
      start_renderer "$@"
      ;;
    restart)
      restart_renderer "$@"
      ;;
    attach)
      attach_renderer
      ;;
    stop)
      stop_renderer
      ;;
    update)
      update_checkout
      ;;
    bluetooth)
      run_bluetooth "$@"
      ;;
    doctor)
      run_doctor "$@"
      ;;
    install-system|install|migrate)
      install_system "$@"
      ;;
    quit|exit)
      exit 0
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Unknown liquid command: $command" >&2
      usage >&2
      exit 2
      ;;
  esac
}

dispatch "$@"
